generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Category {
  id                String        @id @default(uuid())
  code              String        @unique
  name              String
  description       String?       @db.Text
  type              CategoryType
  
  // Hierarchy
  parentId          String?
  level             Int           @default(0)  // 0 = root, 1 = child, etc.
  
  // For Violations
  severity          ViolationSeverity?
  defaultPoints     Int           @default(0)
  minPoints         Int?
  maxPoints         Int?
  sanctionTemplate  String?       @db.Text
  
  // For Achievements
  achievementType   AchievementType?
  basePoints        Int?          // Base points for achievements
  
  // Icon & Display
  icon              String?       // Icon name (lucide-react)
  color             String?       // Hex color for UI
  order             Int           @default(0)
  
  // Usage Statistics
  usageCount        Int           @default(0)
  lastUsedAt        DateTime?
  
  // Meta
  isActive          Boolean       @default(true)
  isSystem          Boolean       @default(false)  // System categories can't be deleted
  createdBy         String
  createdAt         DateTime      @default(now())
  updatedBy         String?
  updatedAt         DateTime      @updatedAt
  deletedAt         DateTime?
  deletedBy         String?
  
  // Relations
  parent            Category?     @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children          Category[]    @relation("CategoryHierarchy")
  
  @@index([code])
  @@index([type])
  @@index([parentId])
  @@index([severity])
  @@map("categories")
}

model CategoryTemplate {
  id            String        @id @default(uuid())
  name          String
  description   String?
  type          CategoryType
  categories    Json          // Array of category objects
  isDefault     Boolean       @default(false)
  createdBy     String
  createdAt     DateTime      @default(now())
  
  @@map("category_templates")
}

model PointsConfiguration {
  id                    String    @id @default(uuid())
  configKey             String    @unique
  configValue           Json
  description           String?
  
  // For tracking changes
  previousValue         Json?
  changedBy             String?
  changedAt             DateTime?
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  
  @@map("points_configurations")
}

model Class {
  id                String    @id @default(uuid())
  code              String    @unique       // X-IPA-1
  name              String                  // 10 IPA 1
  level             String                  // 10, 11, 12
  major             String?                 // IPA, IPS, BAHASA
  
  // Homeroom Teacher
  waliKelasId       String?
  waliKelasName     String?
  
  // Capacity
  capacity          Int       @default(36)
  currentTotal      Int       @default(0)
  
  // Academic
  academicYear      String    // 2024/2025
  
  // Classroom Info
  roomNumber        String?
  floor             String?
  building          String?
  
  // Schedule
  scheduleUrl       String?   // Link to class schedule
  
  // Meta
  isActive          Boolean   @default(true)
  createdBy         String
  createdAt         DateTime  @default(now())
  updatedBy         String?
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?
  
  @@unique([code, academicYear])
  @@index([level])
  @@index([academicYear])
  @@index([waliKelasId])
  @@map("classes")
}

model Subject {
  id                String    @id @default(uuid())
  code              String    @unique       // MAT, BIO, etc.
  name              String                  // Matematika, Biologi
  description       String?
  
  // Meta
  isActive          Boolean   @default(true)
  createdBy         String
  createdAt         DateTime  @default(now())
  updatedBy         String?
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?
  
  @@map("subjects")
}

enum CategoryType {
  VIOLATION
  ACHIEVEMENT
  SUBJECT
}

enum ViolationSeverity {
  RINGAN
  SEDANG
  BERAT
}

enum AchievementType {
  ACADEMIC
  NON_ACADEMIC
  SPORTS
  ARTS
  SCIENCE
  TECHNOLOGY
  LANGUAGE
  RELIGIOUS
  SOCIAL
  OTHER
}
